<?xml version="1.0" encoding="utf-8"?>
<!--
  Kinematic URDF for the FAFU follower arm.

  The six joint transforms, axes and limits describe the FAFU arm kinematic
  chain. The tool offset is 0.175 m along URDF link6 X: the FAFU gripper's
  0.005 m coupling plus its 0.170 m acting-center offset. This replaces the
  older 0.165 m tool offset.
-->
<robot name="fafu_arm">
  <link name="base_link"/>
  <link name="link1"/>
  <link name="link2"/>
  <link name="link3"/>
  <link name="link4"/>
  <link name="link5"/>
  <link name="link6"/>
  <link name="tool_link"/>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0.0584" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.4" upper="2.4" effort="21" velocity="4.2"/>
  </joint>

  <joint name="joint2" type="revolute">
    <origin xyz="0.018199 0 0.053" rpy="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="3.2" effort="36" velocity="5.0"/>
  </joint>

  <joint name="joint3" type="revolute">
    <origin xyz="-0.26 0 0" rpy="0 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="4.0" effort="36" velocity="5.0"/>
  </joint>

  <joint name="joint4" type="revolute">
    <origin xyz="0.23 0 0.06" rpy="0 0 0"/>
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.6" upper="1.6" effort="21" velocity="4.2"/>
  </joint>

  <joint name="joint5" type="revolute">
    <origin xyz="0.07 0 0.036319" rpy="0 0 0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.7" upper="1.7" effort="10" velocity="3.7"/>
  </joint>

  <joint name="joint6" type="revolute">
    <origin xyz="0.02345 0 -0.039" rpy="0 0 0"/>
    <parent link="link5"/>
    <child link="link6"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.5" upper="2.5" effort="10" velocity="3.7"/>
  </joint>

  <joint name="tool_joint" type="fixed">
    <origin xyz="0.175 0 0" rpy="0 0 0"/>
    <parent link="link6"/>
    <child link="tool_link"/>
  </joint>
</robot>
